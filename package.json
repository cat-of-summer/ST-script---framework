{
  "name": "@cat-of-summer/st-script",
  "version": "0.1.0",
  "description": "Standalone JS classes/components (Modal, App, Typograf  , …), shipped as ESM and IIFE/CDN builds.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cat-of-summer/ST-script---framework.git"
  },
  "files": [
    "src",
    "dist"
  ],
  "exports": {
    "./*": "./dist/*.esm.min.js",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "node scripts/build.mjs",
    "prepack": "node scripts/build.mjs"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
