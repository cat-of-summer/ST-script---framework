{
  "name": "@cat-of-summer/st-script",
  "version": "0.1.0",
  "description": "Standalone JS classes/components (st_modal, st_app, st_typograf, …), shipped as ESM and IIFE/CDN builds.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cat-of-summer/js_classes.git"
  },
  "files": [
    "src",
    "dist"
  ],
  "main": "dist/index.esm.min.js",
  "module": "dist/index.esm.min.js",
  "exports": {
    ".": "./dist/index.esm.min.js",
    "./*": "./dist/*.esm.min.js",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "prepare": "node scripts/build.mjs",
    "prepack": "node scripts/build.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
